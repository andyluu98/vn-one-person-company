# VN Business OS — API keys template
# Copy file này thành <vault>/.env và điền key thật.
# File .env đã được .gitignore — KHÔNG bao giờ commit lên git.

# Tavily — search luật/đối thủ/web (free tier 1000 req/tháng tại https://tavily.com)
TAVILY_API_KEY=

# Anthropic — chỉ cần nếu KHÔNG dùng MCP sampling qua Claude Desktop
# Khi chạy qua Claude Desktop subscription thì BỎ QUA key này
ANTHROPIC_API_KEY=

# Google Gemini — fallback LLM (optional)
GOOGLE_API_KEY=

# OpenAI GPT — fallback LLM (optional)
OPENAI_API_KEY=

# Brave Search — alternative search (future, optional)
BRAVE_API_KEY=
